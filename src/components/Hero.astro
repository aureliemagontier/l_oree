---
---
<div class="magazine-page h-full" data-density="hard">
  <div class="page-content flex flex-col justify-between items-center text-center bg-dark text-light">
    <div class="w-full">
      <div class="border-2 border-highlight p-1 inline-block mb-8">
        <div class="border border-highlight px-4 py-1 text-highlight uppercase tracking-[0.25em] text-xs font-bold">
          Édition 2026
        </div>
      </div>
      
      <h1 class="text-6xl md:text-7xl font-serif font-black tracking-tighter mb-4 text-highlight">
        L'ORÉE
      </h1>
      
      <div class="h-px w-24 bg-highlight mx-auto mb-8"></div>
      
      <div class="space-y-2 text-sm uppercase tracking-widest text-highlight/80 font-semibold">
        <p>Identité de marque</p>
        <p>Création graphique</p>
        <p>Création de site web</p>
        <p>Stratégie de communication</p>
      </div>
    </div>

    <div class="relative w-full aspect-[4/5] max-h-[40vh] overflow-hidden rounded-sm shadow-2xl border-4 border-highlight/20">
      <img 
        src="https://picsum.photos/seed/loree-hero/800/1000?grayscale" 
        alt="Aurélie Magontier" 
        class="w-full h-full object-cover opacity-80"
        referrerpolicy="no-referrer"
      />
      <div class="absolute inset-0 bg-dark/30"></div>
    </div>

    <div class="w-full">
      <button class="px-10 py-4 bg-highlight text-dark rounded-full font-bold uppercase tracking-widest text-sm hover:-translate-y-1 transition-transform shadow-lg">
        Découvrir Plus
      </button>
      
      <div class="mt-8 flex justify-between text-[10px] uppercase tracking-widest text-highlight/50 font-bold">
        <div>Aurélie Magontier</div>
        <div>Fondatrice</div>
      </div>
    </div>
  </div>
</div>
