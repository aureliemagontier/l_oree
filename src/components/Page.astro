---
interface Props {
  pageNumber: number;
  totalPages: number;
  tabLabel?: string;
}

const { pageNumber, totalPages, tabLabel = `Page ${pageNumber}` } = Astro.props;
const tabId = `radio-page-${pageNumber}`;
const tabTop = `${4 + (pageNumber - 1) * 4}rem`;

// Computations for dynamic z-index based on page number
const defaultZ = totalPages - pageNumber + 10;
const flippedZ = pageNumber;

// ID des états globaux (Boutons Radios définis dans Book.astro)
const forwardRadioId = `radio-page-${pageNumber}`;
const backwardRadioId = `radio-page-${pageNumber - 1}`;
---

<div class="page-container" id={`page-container-${pageNumber}`}>
  <label for={tabId} class="page-tab page-tab-front hidden md:flex pointer-events-auto items-center justify-center text-[9px] uppercase tracking-[0.3em] font-bold text-dark bg-white/95 border border-zinc-200 shadow-sm rounded-r-3xl px-3 py-2" style={`top: ${tabTop};`}>
    <span>{tabLabel}</span>
  </label>
  <label for={tabId} class="page-tab page-tab-back hidden md:flex pointer-events-auto items-center justify-center text-[9px] uppercase tracking-[0.3em] font-bold text-dark bg-white/95 border border-zinc-200 shadow-sm rounded-l-3xl px-3 py-2" style={`top: ${tabTop};`}>
    <span>{tabLabel}</span>
  </label>
  <!-- Recto (Front of the page, visible when unflipped on the right side) -->
  <div class="side front">
    <slot name="bg-front" />
    <div class="content">
      <slot name="front" />
    </div>

    <!-- Navigation Inférieure (Bouton Suivant uniquement à droite) -->
    <div class="nav-front absolute bottom-4 right-0 z-20 pointer-events-none">
      {pageNumber < totalPages && (
        <label for={forwardRadioId} class="page-tab nav-tab nav-tab-front hidden md:flex pointer-events-auto items-center justify-center gap-2 text-[9px] uppercase tracking-[0.3em] font-bold text-dark bg-white/95 border border-zinc-200 shadow-sm rounded-r-3xl px-3 py-2" tabindex="0" role="button" aria-label="Page suivante">
          <span class="hidden lg:inline">Suivant</span>
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-arrow-right"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </label>
      )}
    </div>
  </div>

  <!-- Verso (Back of the page, visible when flipped on the left side) -->
  <div class="side back">
    <slot name="bg-back" />
    
    <div class="content">
      <slot name="back" />
    </div>
    
    <!-- Navigation Inférieure (Bouton Précédent uniquement à gauche du livre) -->
    <div class="nav-back absolute bottom-4 left-0 z-20 pointer-events-none">
      <label for={backwardRadioId} class="page-tab nav-tab nav-tab-back hidden md:flex pointer-events-auto items-center justify-center gap-2 text-[9px] uppercase tracking-[0.3em] font-bold text-dark bg-white/95 border border-zinc-200 shadow-sm rounded-l-3xl px-3 py-2" tabindex="0" role="button" aria-label="Page précédente">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-arrow-left"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
        <span class="hidden lg:inline">Précédent</span>
      </label>
    </div>
  </div>
</div>

<style define:vars={{ defaultZ, flippedZ }}>
  .page-container {
    position: absolute;
    top: 0;
    left: 50%; /* Position on the right half of the book */
    width: 50%;
    height: 100%;
    transform-origin: left center;
    transform-style: preserve-3d;
    z-index: var(--defaultZ);
    /* Transformation gérée par Book.astro, transition gérée ici */
    transition: transform 0.6s cubic-bezier(0.8, 0.045, 0.355, 1), z-index 0s 0.3s;
  }

  .side {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    -webkit-backface-visibility: hidden;
    backface-visibility: hidden;
    background-color: var(--page-bg);
    border: 1px solid var(--page-border);
    box-sizing: border-box;
    /* Box shadow to simulate page depth slightly */
    box-shadow: inset 0 0 15px rgba(0,0,0,0.02), 2px 2px 5px var(--page-shadow);
    display: flex;
    flex-direction: column;
  }

  /* The back is rotated 180deg natively so it faces opposite */
  .side.back {
    transform: rotateY(180deg);
    /* Shadow on the opposite side to give depth when flipped */
    box-shadow: inset 0 0 15px rgba(0,0,0,0.02), -2px 2px 5px var(--page-shadow);
  }

  .content {
    flex-grow: 1;
    overflow-y: auto;
    padding: 0.5rem 0.5rem 2rem;
    width: 99%;
  }

  .page-tab {
    position: absolute;
    right: -5.5rem;
    transform: translateY(-50%);
    width: 6rem;
    max-width: 6rem;
    min-height: 3rem;
    z-index: 30;
    white-space: normal;
    text-align: center;
    overflow: hidden;
    text-overflow: ellipsis;
    display: flex;
    align-items: center;
    justify-content: center;
    line-height: 1.1;
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
  }

  .page-tab-back {
    left: calc(100% - 1em);
    right: auto;
    transform: translateY(-50%) rotateY(180deg);
  }

  .nav-tab {
    bottom: 4rem;
    top: auto;
    transform: none;
  }

  .nav-tab-front {
    right: -5.5rem;
  }

  .nav-tab-back {
    left: calc(100% - 10em);
  }

   @media (max-width: 768px) {
      .page-tab-back {
        display: none;
      }
      .page-tab-front{
       display: none;
      }
    
  }


  @media (min-width: 768px) {
    .content {
      padding: 0.5rem 0.5rem 4rem;
    }
  }


  @media (min-width: 768px) {
    .turn-btn {
      padding: 1rem 1.8rem;
      font-size: 1.1rem;
    }
  }

  /* Règle par défaut ciblée : Par défaut, la face arrière (back) est cachée derrière et à l'envers. */
  /* On désactive strictement les balises d'interaction matérielle connues pour libérer les clics. */
  .side.back a,
  .side.back button,
  .side.back label {
    pointer-events: none;
  }

  .turn-btn:hover {
    color: #000;
    background-color: rgba(248, 247, 245, 0.9);
  }

  .turn-btn:focus-visible {
    outline: 2px solid #333;
    outline-offset: 2px;
  }

  /* Hide scrollbar for cleaner book feel */
  .content::-webkit-scrollbar {
    width: 4px;
  }
  .content::-webkit-scrollbar-thumb {
    background: rgba(0,0,0,0.1);
    border-radius: 4px;
  }

  .back-divider-left,
  .back-divider-right {
    position: relative;
    width: 100%;
  }

  .back-divider-left {
    margin-right: auto;
    text-align: left;
    max-width: 75%;
    padding-left: 1rem;
  }

  .back-divider-left::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.75rem;
    width: 4px;
    height: calc(100% - 1.5rem);
    border-radius: 999px;
    background: var(--color-primary);
    opacity: 0.85;
  }

  .back-divider-right {
    margin-left: auto;
    text-align: right;
    max-width: 75%;
    padding-right: 1rem;
  }

  .back-divider-right::before {
    content: '';
    position: absolute;
    right: 0;
    top: 0.75rem;
    width: 4px;
    height: calc(100% - 1.5rem);
    border-radius: 999px;
    background: var(--color-primary);
    opacity: 0.85;
  }
</style>
