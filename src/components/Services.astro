---
import profil3 from '../assets/profil3.jpeg';

interface Props {
  part?: 1 | 2;
  pageNumber?: number;
}

const { part = 1, pageNumber } = Astro.props;
---
<div class="magazine-page h-full">
  <div class="page-content h-full flex flex-col relative">
    {part === 1 && (
      <>
        <div class="mb-8">
          <h2 class="text-3xl font-serif font-bold text-primary mb-1">Ce que je crée</h2>
          <div class="h-1 w-16 bg-primary"></div>
        </div>

        <div class="grid grid-cols-1 gap-4 flex-grow flex flex-col justify-center">
          <div class="p-5 bg-white rounded-[2rem] shadow-sm border border-zinc-100 hover:shadow-md transition-shadow flex gap-5 items-center">
            <div class="flex-shrink-0 w-12 h-12 bg-accent/20 rounded-full flex items-center justify-center text-accent">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-palette"><circle cx="13.5" cy="6.5" r="2.5"/><circle cx="17.5" cy="10.5" r="2.5"/><circle cx="8.5" cy="7.5" r="2.5"/><circle cx="6.5" cy="12.5" r="2.5"/><path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10c.9 0 1.6-.7 1.6-1.6 0-.4-.2-.8-.5-1.1s-.5-.8-.5-1.2c0-.9.7-1.6 1.6-1.6H19c2.2 0 4-1.8 4-4 0-5.5-4.5-10-10-10z"/></svg>
            </div>
            <div>
              <h3 class="text-lg font-serif font-bold text-dark mb-1 leading-tight">Création graphique</h3>
              <p class="text-xs text-dark/70 leading-relaxed font-poppins">
                Supports de communication adaptés à votre identité pour raconter votre story avec authenticité.
              </p>
            </div>
          </div>

          <div class="p-5 bg-white rounded-[2rem] shadow-sm border border-zinc-100 hover:shadow-md transition-shadow flex gap-5 items-center">
            <div class="flex-shrink-0 w-12 h-12 bg-primary/20 rounded-full flex items-center justify-center text-primary">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-layout"><rect width="18" height="18" x="3" y="3" rx="2" ry="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="9" y1="21" x2="9" y2="9"/></svg>
            </div>
            <div>
              <h3 class="text-lg font-serif font-bold text-dark mb-1 leading-tight">Création de Site Web</h3>
              <p class="text-xs text-dark/70 leading-relaxed font-poppins">
                Sites web modernes et responsifs, conçus pour refléter votre univers et convertir vos visiteurs.
              </p>
            </div>
          </div>

          <div class="p-5 bg-white rounded-[2rem] shadow-sm border border-zinc-100 hover:shadow-md transition-shadow flex gap-5 items-center">
            <div class="flex-shrink-0 w-12 h-12 bg-accent/20 rounded-full flex items-center justify-center text-accent">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-pen-nib"><path d="m13.4 2 5.6 5.6-3 3L11 5.6Z"/><path d="m6.2 17.8 3.1-3.1"/><path d="M2 22c.3-3.2 1.4-4.9 3.5-7l3.1 3.1c-2.1 2.1-3.8 3.2-7 3.5Z"/><path d="m11 5.6 5.4 5.4-5.8 5.8-10.6 5.2 5.2-10.6Z"/></svg>
            </div>
            <div>
              <h3 class="text-lg font-serif font-bold text-dark mb-1 leading-tight">Identité Visuelle</h3>
              <p class="text-xs text-dark/70 leading-relaxed font-poppins">
                Logo, charte graphique et branding complet pour une image cohérente et distinctive.
              </p>
            </div>
          </div>

          <div class="p-5 bg-white rounded-[2rem] shadow-sm border border-zinc-100 hover:shadow-md transition-shadow flex gap-5 items-center">
            <div class="flex-shrink-0 w-12 h-12 bg-primary/20 rounded-full flex items-center justify-center text-primary">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-target"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/></svg>
            </div>
            <div>
              <h3 class="text-lg font-serif font-bold text-dark mb-1 leading-tight">Stratégie de Communication</h3>
              <p class="text-xs text-dark/70 leading-relaxed font-poppins">
                Stratégie claire et alignée pour renforcer votre positionnement et amplifier votre visibilité.
              </p>
            </div>
          </div>
        </div>
      </>
    )}

    {part === 2 && (
      <div class="flex flex-col flex-grow justify-center">
        <div class="relative mb-12">
          <div class="absolute -top-10 -left-6 text-primary/10">
            <svg xmlns="http://www.w3.org/2000/svg" width="120" height="120" viewBox="0 0 24 24" fill="currentColor"><path d="M14.017 21L14.017 18C14.017 16.8954 14.9124 16 16.017 16H19.017C19.5693 16 20.017 15.5523 20.017 15V9C20.017 8.44772 19.5693 8 19.017 8H16.017C14.9124 8 14.017 7.10457 14.017 6V5C14.017 3.89543 14.9124 3 16.017 3H19.017C21.2261 3 23.017 4.79086 23.017 7V15C23.017 18.3137 20.3307 21 17.017 21H14.017ZM1 21L1 18C1 16.8954 1.89543 16 3 16H6C6.55228 16 7 15.5523 7 15V9C7 8.44772 6.55228 8 6 8H3C1.89543 8 1 7.10457 1 6V5C1 3.89543 1.89543 3 3 3H6C8.20914 3 10 4.79086 10 7V15C10 18.3137 7.31371 21 4 21H1Z"/></svg>
          </div>
          <div class="p-8 bg-primary text-white rounded-[3rem] shadow-2xl relative z-10">
            <div class="flex flex-col items-center text-center gap-6">
              <div class="w-32 h-32 rounded-full overflow-hidden border-4 border-white/20 shadow-inner">
                <img src={profil3.src} alt="Aurélie Magontier" class="w-full h-full object-cover" style="object-position: 50% 10%;" />
              </div>
              <div>
                <h3 class="text-2xl font-serif font-bold text-highlight mb-3">Ma Philosophie</h3>
                <p class="text-sm italic leading-relaxed opacity-90 font-poppins">
                  "Je crois que chaque entreprise porte une histoire unique. Mon rôle est de vous aider à la transmettre avec clarté, douceur et authenticité."
                </p>
              </div>
            </div>
          </div>
        </div>

        <div class="grid grid-cols-2 gap-4">
          <div class="p-6 rounded-3xl bg-[#A793AC] border border-accent/20 flex flex-col items-center text-center gap-2">
            <div class="text-white">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-heart"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg>
            </div>
            <p class="text-[11px] font-bold uppercase tracking-widest text-white/80">Sensibilité</p>
          </div>
          <div class="p-6 rounded-3xl bg-accent/10 border border-accent/20 flex flex-col items-center text-center gap-2">
            <div class="text-accent">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-sparkles"><path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3Z"/><path d="M5 3v4"/><path d="M19 17v4"/><path d="M3 5h4"/><path d="M17 19h4"/></svg>
            </div>
            <p class="text-[11px] font-bold uppercase tracking-widest text-dark/60">Clarté</p>
          </div>
        </div>
      </div>
    )}
    {pageNumber && (
      <div class={`absolute bottom-4 ${part === 1 ? 'left-4' : 'right-4'} text-[10px] font-serif text-black italic`}>
        {pageNumber}
      </div>
    )}
  </div>
  <!-- Page Navigation Buttons -->
  {part === 1 && (
    <button class="st-ignore btn-prev-page absolute left-2 top-1/2 -translate-y-1/2 w-10 h-10 rounded-full bg-highlight shadow-lg border-2 border-accent flex items-center justify-center text-accent hover:bg-accent hover:text-highlight transition-all z-50">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
    </button>
  )}
  {part === 2 && (
    <button class="st-ignore btn-next-page absolute right-2 top-1/2 -translate-y-1/2 w-10 h-10 rounded-full bg-highlight shadow-lg border-2 border-accent flex items-center justify-center text-accent hover:bg-accent hover:text-highlight transition-all z-50">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
    </button>
  )}

</div>
