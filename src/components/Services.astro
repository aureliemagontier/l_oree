---
import profil3 from '../assets/profil3.jpeg';
---
<div class="magazine-page h-full">
  <div class="page-content h-full flex flex-col">
    <div class="mb-4">
      <h2 class="text-2xl font-serif font-bold text-primary mb-1">Ce que je crée</h2>
      <div class="h-1 w-16 bg-primary"></div>
    </div>

    <div class="grid grid-cols-1 gap-2 flex-grow overflow-hidden">
      <div class="p-3 bg-white rounded-2xl shadow-sm border border-zinc-100 hover:shadow-md transition-shadow flex gap-3 items-center">
        <div class="flex-shrink-0 w-9 h-9 bg-accent/20 rounded-full flex items-center justify-center text-accent">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-palette"><circle cx="13.5" cy="6.5" r="2.5"/><circle cx="17.5" cy="10.5" r="2.5"/><circle cx="8.5" cy="7.5" r="2.5"/><circle cx="6.5" cy="12.5" r="2.5"/><path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10c.9 0 1.6-.7 1.6-1.6 0-.4-.2-.8-.5-1.1s-.5-.8-.5-1.2c0-.9.7-1.6 1.6-1.6H19c2.2 0 4-1.8 4-4 0-5.5-4.5-10-10-10z"/></svg>
        </div>
        <div>
          <h3 class="text-base font-serif font-bold text-dark mb-0.5 leading-tight">Création graphique</h3>
          <p class="text-[10px] text-dark/70 leading-tight font-poppins">
            Supports de communication adaptés à votre identité pour raconter votre story avec authenticité.
          </p>
        </div>
      </div>

      <div class="p-3 bg-white rounded-2xl shadow-sm border border-zinc-100 hover:shadow-md transition-shadow flex gap-3 items-center">
        <div class="flex-shrink-0 w-9 h-9 bg-primary/20 rounded-full flex items-center justify-center text-primary">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-layout"><rect width="18" height="18" x="3" y="3" rx="2" ry="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="9" y1="21" x2="9" y2="9"/></svg>
        </div>
        <div>
          <h3 class="text-base font-serif font-bold text-dark mb-0.5 leading-tight">Création de Site Web</h3>
          <p class="text-[10px] text-dark/70 leading-tight font-poppins">
            Sites web modernes et responsifs, conçus pour refléter votre univers et convertir vos visiteurs.
          </p>
        </div>
      </div>

      <div class="p-3 bg-white rounded-2xl shadow-sm border border-zinc-100 hover:shadow-md transition-shadow flex gap-3 items-center">
        <div class="flex-shrink-0 w-9 h-9 bg-accent/20 rounded-full flex items-center justify-center text-accent">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-pen-nib"><path d="m13.4 2 5.6 5.6-3 3L11 5.6Z"/><path d="m6.2 17.8 3.1-3.1"/><path d="M2 22c.3-3.2 1.4-4.9 3.5-7l3.1 3.1c-2.1 2.1-3.8 3.2-7 3.5Z"/><path d="m11 5.6 5.4 5.4-5.8 5.8-10.6 5.2 5.2-10.6Z"/></svg>
        </div>
        <div>
          <h3 class="text-base font-serif font-bold text-dark mb-0.5 leading-tight">Identité Visuelle</h3>
          <p class="text-[10px] text-dark/70 leading-tight font-poppins">
            Logo, charte graphique et branding complet pour une image cohérente et distinctive.
          </p>
        </div>
      </div>

      <div class="p-3 bg-white rounded-2xl shadow-sm border border-zinc-100 hover:shadow-md transition-shadow flex gap-3 items-center">
        <div class="flex-shrink-0 w-9 h-9 bg-primary/20 rounded-full flex items-center justify-center text-primary">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-target"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/></svg>
        </div>
        <div>
          <h3 class="text-base font-serif font-bold text-dark mb-0.5 leading-tight">Stratégie de Communication</h3>
          <p class="text-[10px] text-dark/70 leading-tight font-poppins">
            Stratégie claire et alignée pour renforcer votre positionnement et amplifier votre visibilité.
          </p>
        </div>
      </div>
    </div>

    <div class="mt-4 p-4 bg-primary text-white rounded-2xl shadow-xl flex gap-4 items-center">
      <div class="flex-shrink-0 w-20 h-20 rounded-full overflow-hidden border-2 border-white/20">
        <img src={profil3.src} alt="Aurélie Magontier" class="w-full h-full object-cover" style="object-position: 50% 10%;" />
      </div>
      <div class="flex-grow">
        <h3 class="text-base font-serif font-bold text-highlight mb-0.5">Ma Philosophie</h3>
        <p class="text-[10px] italic leading-tight opacity-90 font-poppins">
          "Je crois que chaque entreprise porte une histoire unique. Mon rôle est de vous aider à la transmettre avec clarté."
        </p>
      </div>
    </div>
  </div>

  <!-- Page Navigation Buttons -->
  <button class="st-ignore btn-prev-page absolute left-2 top-1/2 -translate-y-1/2 w-10 h-10 rounded-full bg-highlight shadow-lg border-2 border-accent flex items-center justify-center text-accent hover:bg-accent hover:text-highlight transition-all z-50">
    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
  </button>
</div>
