---
<div class="magazine-page h-full" data-density="hard">
  <div class="page-content flex flex-col justify-center items-center text-center bg-dark text-light">
    <div class="w-full max-w-xs">
      <div class="h-px w-full bg-highlight/20 mb-12"></div>
      
      <h2 class="text-4xl font-serif font-black tracking-tighter mb-4 text-highlight">
        L'ORÉE
      </h2>
      
      <p class="text-xs uppercase tracking-[0.5em] text-highlight/60 font-bold mb-12">
        ÉDITION 2026
      </p>

      <div class="space-y-4 text-[10px] uppercase tracking-widest text-highlight/40 font-bold">
        <p>© 2026 L'ORÉE DESIGN</p>
        <p>TOUS DROITS RÉSERVÉS</p>
        <p>CONCEPTION : AURÉLIE MAGONTIER</p>
      </div>

      <div class="h-px w-full bg-highlight/20 mt-12"></div>
      
      <div class="mt-12 flex justify-center gap-8">
        <div class="w-8 h-8 rounded-full border border-highlight/20 flex items-center justify-center text-highlight/40 hover:text-highlight hover:border-highlight transition-all cursor-pointer">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-instagram"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
        </div>
        <div class="w-8 h-8 rounded-full border border-highlight/20 flex items-center justify-center text-highlight/40 hover:text-highlight hover:border-highlight transition-all cursor-pointer">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-linkedin"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/></svg>
        </div>
        <div class="w-8 h-8 rounded-full border border-highlight/20 flex items-center justify-center text-highlight/40 hover:text-highlight hover:border-highlight transition-all cursor-pointer">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-facebook"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
        </div>
      </div>
    </div>
  </div>
</div>
