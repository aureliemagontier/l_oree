---
import Page from '../Page.astro';

interface Props {
  totalPages: number;
}
const { totalPages } = Astro.props;
---

<Page pageNumber={2} totalPages={totalPages}> 
  <Fragment slot="front">
    <div class="flex-grow relative pt-8">
      <div class="prose prose-zinc text-[10px] md:text-[12px] leading-relaxed text-dark/80 font-poppins italic mb-8 md:mb-12">
        <p class="mb-4 font-poppins">
          J’aime écouter les nuances, les hésitations, les élans.
          J’aime sentir ce qui cherche à émerger.
          Et j’aime accompagner ce moment où tout s’aligne — où la personne se reconnaît enfin dans ce que son entreprise montre au monde.
        </p>
        <p class="font-bold text-dark mt-6 md:mt-8 border-t border-[#79B6D8]/30 pt-4 font-sans">
          Un soutien discret.
          Une expertise sensible.
          Un chemin vers l’essentiel.
        </p>
        <p class="text-right font-serif text-base md:text-lg text-primary mt-4">
          Aurélie
        </p>
      </div>
      <!-- 
      <div class="grid grid-cols-1 md:grid-cols-2 gap-3 md:gap-4 mt-8">
        <div class="p-3 md:p-4 bg-[#F5EBC8] rounded-lg border border-secondary/30">
          <h3 class="text-[10px] md:text-xs font-bold uppercase tracking-widest text-dark/60 mb-2 font-sans">Philosophie</h3>
          <p class="text-[10px] md:text-[12px] font-poppins italic">Transformer la complexité en clarté</p>
        </div>
        <div class="p-3 md:p-4 bg-primary/10 rounded-lg border border-primary/20">
          <h3 class="text-[10px] md:text-xs font-bold uppercase tracking-widest text-dark/60 mb-2 font-sans">Expertise</h3>
          <p class="text-[10px] md:text-[12px] font-poppins italic">Identité de marque, Stratégie, Création graphique & Sites Web</p>
        </div>-->
      </div>
    </div>
  </Fragment>
  <Fragment slot="back">
    <div class="mb-8">
      <h2 class="text-3xl font-serif font-bold text-primary mb-1">Ce que je crée</h2>
      <div class="h-1 w-16 bg-primary"></div>
    </div>

    <div class="grid grid-cols-1 gap-4 flex-grow">
      <div class="p-4 md:p-5 bg-white rounded-2xl md:rounded-[2rem] shadow-sm border border-zinc-100 hover:shadow-md transition-shadow flex gap-4 md:gap-5 items-center">
        <div class="flex-shrink-0 w-10 h-10 md:w-12 md:h-12 bg-accent/20 rounded-full flex items-center justify-center text-accent">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" md:width="24" md:height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-palette"><circle cx="13.5" cy="6.5" r="2.5"/><circle cx="17.5" cy="10.5" r="2.5"/><circle cx="8.5" cy="7.5" r="2.5"/><circle cx="6.5" cy="12.5" r="2.5"/><path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10c.9 0 1.6-.7 1.6-1.6 0-.4-.2-.8-.5-1.1s-.5-.8-.5-1.2c0-.9.7-1.6 1.6-1.6H19c2.2 0 4-1.8 4-4 0-5.5-4.5-10-10-10z"/></svg>
        </div>
        <div>
          <h3 class="text-base md:text-lg font-serif font-bold text-dark mb-1 leading-tight">Création graphique</h3>
          <p class="text-[10px] md:text-xs text-dark/70 leading-relaxed font-poppins">
            Supports de communication adaptés à votre identité pour raconter votre story avec authenticité.
          </p>
        </div>
      </div>

      <div class="p-4 md:p-5 bg-white rounded-2xl md:rounded-[2rem] shadow-sm border border-zinc-100 hover:shadow-md transition-shadow flex gap-4 md:gap-5 items-center">
        <div class="flex-shrink-0 w-10 h-10 md:w-12 md:h-12 bg-primary/20 rounded-full flex items-center justify-center text-primary">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" md:width="24" md:height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-layout"><rect width="18" height="18" x="3" y="3" rx="2" ry="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="9" y1="21" x2="9" y2="9"/></svg>
        </div>
        <div>
          <h3 class="text-base md:text-lg font-serif font-bold text-dark mb-1 leading-tight">Création de Site Web</h3>
          <p class="text-[10px] md:text-xs text-dark/70 leading-relaxed font-poppins">
            Sites web modernes et responsifs, conçus pour refléter votre univers et convertir vos visiteurs.
          </p>
        </div>
      </div>

      <div class="p-4 md:p-5 bg-white rounded-2xl md:rounded-[2rem] shadow-sm border border-zinc-100 hover:shadow-md transition-shadow flex gap-4 md:gap-5 items-center">
        <div class="flex-shrink-0 w-10 h-10 md:w-12 md:h-12 bg-accent/20 rounded-full flex items-center justify-center text-accent">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" md:width="24" md:height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-pen-nib"><path d="m13.4 2 5.6 5.6-3 3L11 5.6Z"/><path d="m6.2 17.8 3.1-3.1"/><path d="M2 22c.3-3.2 1.4-4.9 3.5-7l3.1 3.1c-2.1 2.1-3.8 3.2-7 3.5Z"/><path d="m11 5.6 5.4 5.4-5.8 5.8-10.6 5.2 5.2-10.6Z"/></svg>
        </div>
        <div>
          <h3 class="text-base md:text-lg font-serif font-bold text-dark mb-1 leading-tight">Identité Visuelle</h3>
          <p class="text-[10px] md:text-xs text-dark/70 leading-relaxed font-poppins">
            Logo, charte graphique et branding complet pour une image cohérente et distinctive.
          </p>
        </div>
      </div>

      <div class="p-4 md:p-5 bg-white rounded-2xl md:rounded-[2rem] shadow-sm border border-zinc-100 hover:shadow-md transition-shadow flex gap-4 md:gap-5 items-center">
        <div class="flex-shrink-0 w-10 h-10 md:w-12 md:h-12 bg-primary/20 rounded-full flex items-center justify-center text-primary">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" md:width="24" md:height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-target"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/></svg>
        </div>
        <div>
          <h3 class="text-base md:text-lg font-serif font-bold text-dark mb-1 leading-tight">Stratégie de Communication</h3>
          <p class="text-[10px] md:text-xs text-dark/70 leading-relaxed font-poppins">
            Stratégie claire et alignée pour renforcer votre positionnement et amplifier votre visibilité.
          </p>
        </div>
      </div>
    </div>
  </Fragment>
</Page>
