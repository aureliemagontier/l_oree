---
import Page from "../Page.astro";

interface Props {
    totalPages: number;
    tabLabel?: string;
}
const { totalPages, tabLabel } = Astro.props;
---

<Page pageNumber={9} totalPages={totalPages} tabLabel={tabLabel}>
    <Fragment slot="front">
        <div class="flex-grow flex flex-col space-y-6 pt-0">
            <section>
                <h3 class="text-lg md:text-xl font-serif font-bold text-dark mb-2">Contexte du projet</h3>
                <p class="font-sans text-[12px] md:text-[14px] text-dark/80 leading-relaxed">
                    Rayonis Academy est une entreprise qui s’adresse aux jeunes, aux parents et aux enseignants, pour découvrir l’intelligence artificielle, la robotique et la création numérique. Le client souhaitait un site capable de parler aux adolescents tout en restant clair et rassurant pour les adultes. L’objectif : créer un espace où la technologie devient un terrain de jeu, un lieu d’exploration et de transmission.
                </p>
            </section>

            <section>
                <h3 class="text-lg md:text-xl font-serif font-bold text-dark mb-2">Concept & Direction artistique</h3>
                <p class="font-sans text-[12px] md:text-[14px] text-dark/80 leading-relaxed">
                    Pour rendre l’apprentissage plus ludique et moins intimidant, j’ai imaginé une interface inspirée des bornes d’arcade rétro‑futuristes. Ce choix permet d’immerger immédiatement l’utilisateur dans un univers ludique, de créer un pont entre générations et de rendre l’IA plus accessible. L’esthétique mêle néons, grilles vectorielles, typographies pixelisées et ambiance OS rétro, pour une expérience immersive et mémorable.
                </p>
            </section>

            <section>
                <h3 class="text-lg md:text-xl font-serif font-bold text-dark mb-2">Fonctionnalités clés</h3>
                <ul class="font-sans text-[12px] md:text-[14px] text-dark/80 leading-relaxed space-y-1">
                    <li class="flex gap-2"><span class="text-primary">•</span> Navigation au clavier (A / B / C / H) pour une expérience arcade authentique</li>
                    <li class="flex gap-2"><span class="text-primary">•</span> Interface immersive inspirée des systèmes rétro</li>
                    <li class="flex gap-2"><span class="text-primary">•</span> 3 modules pédagogiques : Conférence participative, Robotique & Intelligence, Game Design & IA</li>
                    <li class="flex gap-2"><span class="text-primary">•</span> Design responsive pensé pour les jeunes publics</li>
                    <li class="flex gap-2"><span class="text-primary">•</span> Ambiance visuelle cohérente avec l’univers du client</li>
                </ul>
            </section>

            <section>
                <h3 class="text-lg md:text-xl font-serif font-bold text-dark mb-2">Résultat</h3>
                <p class="font-sans text-[12px] md:text-[14px] text-dark/80 leading-relaxed">
                    La nouvelle interface améliore nettement l’expérience utilisateur grâce à une navigation plus intuitive, une hiérarchie visuelle claire et une mise en scène des contenus pensée pour guider chaque profil — jeunes, parents et enseignants. L’approche UX centrée sur la simplicité et le jeu facilite la compréhension des modules, renforce l’engagement et crée un parcours fluide, cohérent et rassurant. Cette refonte pose les bases d’une expérience digitale plus accessible, plus immersive et mieux alignée avec les objectifs pédagogiques de Rayonis Academy.
                </p>
            </section>

            <div class="pt-4 flex justify-center">
                <button
                    class="px-6 py-3 rounded-full bg-primary text-white font-sans font-bold text-[10px] md:text-xs uppercase tracking-widest hover:bg-primary/90 transition-all shadow-xl shadow-primary/20 transform hover:-translate-y-1 cursor-pointer inline-block"
                    onclick="window.goToContact()"
                >
                    Me contacter pour votre projet
                </button>
            </div>
        </div>
    </Fragment>
    <Fragment slot="back">
        <div class="h-full flex flex-col px-2 md:px-6">
            <div class="mb-6 mt-2 back-divider-right">
                <h2 class="text-3xl font-serif font-bold text-primary mb-1">
                    Me Contacter
                </h2>
                <div class="h-1 w-16 bg-primary"></div>
            </div>
            
            <p class="font-sans text-[12px] md:text-[14px] text-dark/80 leading-relaxed mb-6">
                Je suis à votre écoute pour toute question, demande ou début
                de projet. Laissez‑moi votre message et je vous répondrai
                avec attention, afin de vous guider avec précision et
                simplicité vers la solution la plus juste pour vous.
            </p>

            <form
                id="contact-form"
                class="space-y-3 md:space-y-4 bg-highlight/20 p-4 md:p-6 rounded-[2rem] md:rounded-[2.5rem] border border-highlight/30 w-full flex-grow relative"
            >
                <div class="space-y-2 md:space-y-3">
                    <div class="space-y-1 font-sans">
                        <label class="text-[8px] md:text-[9px] font-bold uppercase tracking-widest text-dark/60 ml-2">Votre nom</label>
                        <input
                            type="text"
                            name="nom"
                            required
                            class="w-full px-3 md:px-4 py-2 md:py-3 bg-white border border-zinc-200 rounded-xl md:rounded-2xl focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all shadow-sm font-sans text-[10px] md:text-xs"
                            placeholder="Nom Complet"
                        />
                    </div>
                    <div class="space-y-1 font-sans">
                        <label class="text-[8px] md:text-[9px] font-bold uppercase tracking-widest text-dark/60 ml-2">Votre email</label>
                        <input
                            type="email"
                            name="email"
                            required
                            class="w-full px-3 md:px-4 py-2 md:py-3 bg-white border border-zinc-200 rounded-xl md:rounded-2xl focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all shadow-sm font-sans text-[10px] md:text-xs"
                            placeholder="Email"
                        />
                    </div>
                    <div class="space-y-1 font-sans">
                        <label class="text-[8px] md:text-[9px] font-bold uppercase tracking-widest text-dark/60 ml-2">Sujet</label>
                        <input
                            type="text"
                            name="sujet"
                            required
                            class="w-full px-3 md:px-4 py-2 md:py-3 bg-white border border-zinc-200 rounded-xl md:rounded-2xl focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all shadow-sm font-sans text-[10px] md:text-xs"
                            placeholder="Sujet de votre message"
                        />
                    </div>
                    <div class="space-y-1 font-sans">
                        <label class="text-[8px] md:text-[9px] font-bold uppercase tracking-widest text-dark/60 ml-2">Votre message</label>
                        <textarea
                            name="message"
                            required
                            class="w-full px-3 md:px-4 py-2 md:py-3 bg-white border border-zinc-200 rounded-xl md:rounded-2xl focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all shadow-sm h-16 md:h-24 resize-none font-sans text-[10px] md:text-xs"
                            placeholder="Comment puis-je vous aider ?"
                        ></textarea>
                    </div>
                </div>
                <button
                    type="submit"
                    class="w-full py-3 md:py-4 bg-primary text-white rounded-xl md:rounded-2xl font-bold uppercase tracking-widest text-[9px] md:text-[10px] hover:bg-primary/90 transition-all shadow-lg shadow-primary/20 font-sans transform hover:-translate-y-1 mt-2 md:mt-4"
                >
                    Envoyer le message
                </button>
            </form>
        </div>
    </Fragment>
</Page>

<script>
    const setupForm = () => {
        const form = document.getElementById('contact-form') as HTMLFormElement;
        if (form && !form.dataset.initialized) {
            form.dataset.initialized = 'true';
            form.addEventListener('submit', async (e) => {
                e.preventDefault();
                const formData = new FormData(form);
                const data = Object.fromEntries(formData.entries());
                const button = form.querySelector('button[type="submit"]') as HTMLButtonElement;
                const originalText = button.textContent;
                
                button.textContent = "Envoi en cours...";
                button.disabled = true;

                try {
                    const response = await fetch("https://rayonis.app.n8n.cloud/webhook/ffb9cca0-459e-4032-959e-659a4c387074", {
                        method: "POST",
                        body: formData
                    });
                    
                    if (response.ok) {
                        button.textContent = "Message envoyé !";
                        form.reset();
                        setTimeout(() => {
                            button.textContent = originalText;
                            button.disabled = false;
                        }, 5000);
                    } else {
                        throw new Error("Erreur lors de l'envoi");
                    }
                } catch (error) {
                    console.error("Erreur:", error);
                    button.textContent = "Erreur. Réessayez.";
                    setTimeout(() => {
                        button.textContent = originalText;
                        button.disabled = false;
                    }, 3000);
                }
            });
        }
    };

    setupForm();
    document.addEventListener('astro:page-load', setupForm);
</script>
