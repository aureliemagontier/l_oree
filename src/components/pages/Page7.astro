---
import Page from "../Page.astro";

interface Props {
  totalPages: number;
  tabLabel?: string;
}
const { totalPages, tabLabel } = Astro.props;
---

<Page pageNumber={7} totalPages={totalPages} tabLabel={tabLabel}>
  <Fragment slot="front">
    <div class="h-full flex flex-col justify-center items-center">
      <!-- Empty page before the back cover -->
    </div>
  </Fragment>

  <Fragment slot="bg-back">
    <!-- Background Absolute -->
    <div
      class="absolute inset-0 z-0 overflow-hidden pointer-events-none rounded-l-lg bg-black"
    >
      <div
        class="absolute inset-0 bg-cover bg-center"
        style="background-image: url('/aurelie.jpg'); filter: blur(6px); transform: scale(1.02);"
      >
      </div>
      <div class="absolute inset-0 bg-black/60"></div>
    </div>
  </Fragment>

  <Fragment slot="back">
    <!-- Contenu Principal -->
    <div
      class="relative z-10 h-full w-full flex flex-col justify-center items-center text-center text-white p-6 md:p-8"
    >
      <div class="w-full max-w-[280px] md:max-w-xs">
        <div class="h-px w-full bg-highlight/20 mb-8 md:mb-12"></div>

        <h2
          class="text-3xl md:text-4xl lg:text-5xl font-serif font-black tracking-tighter mb-3 md:mb-4 text-highlight"
        >
          L'ORÉE
        </h2>

        <p
          class="text-[10px] md:text-xs uppercase tracking-[0.4em] md:tracking-[0.5em] text-highlight/60 font-bold mb-8 md:mb-12"
        >
          ÉDITION 2026
        </p>

        <div
          class="space-y-3 md:space-y-4 text-[9px] md:text-[10px] uppercase tracking-widest text-highlight/40 font-bold font-sans"
        >
          <p>© 2026 L'ORÉE DESIGN</p>
          <p>TOUS DROITS RÉSERVÉS</p>
          <p>CONCEPTION : AURÉLIE MAGONTIER</p>
        </div>

        <div class="h-px w-full bg-highlight/20 mt-8 md:mt-12"></div>

     <div class="mt-8 md:mt-12 flex flex-col items-center gap-2">
  <a
    href="https://www.instagram.com/loree_by_aurelie"
    target="_blank"
    class="w-7 h-7 md:w-8 md:h-8 rounded-full border border-highlight/20 flex items-center justify-center text-highlight/40 hover:text-highlight hover:border-highlight transition-all cursor-pointer pointer-events-auto"
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      width="14"
      height="14"
      md:width="16"
      md:height="16"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="3"
      stroke-linecap="round"
      stroke-linejoin="round"
      class="lucide lucide-instagram"
    >
      <rect width="20" height="20" x="2" y="2" rx="5" ry="5"></rect>
      <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
      <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
    </svg>
  </a>

  <p class="text-[9px] md:text-[10px] font-sans text-highlight/40 tracking-widest uppercase">
    @loree_by_aurelie
  </p>
</div>

          <!-- logo + 
          <div class="w-7 h-7 md:w-8 md:h-8 rounded-full border border-highlight/20 flex items-center justify-center text-highlight/40 hover:text-highlight hover:border-highlight transition-all cursor-pointer pointer-events-auto hidden">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" md:width="16" md:height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-linkedin"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/></svg>
          </div>
          <div class="w-7 h-7 md:w-8 md:h-8 rounded-full border border-highlight/20 flex items-center justify-center text-highlight/40 hover:text-highlight hover:border-highlight transition-all cursor-pointer pointer-events-auto hidden hidden">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" md:width="16" md:height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-facebook"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
          </div>-->
        </div>
      </div>
    </div>
  </Fragment>
</Page>
