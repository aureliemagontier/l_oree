---
import Page from '../Page.astro';

interface Props {
  totalPages: number;
  tabLabel?: string;
}
const { totalPages, tabLabel } = Astro.props;
---

<Page pageNumber={7} totalPages={totalPages} tabLabel={tabLabel}>


 <Fragment slot="front">
  <div 
    class="min-h-screen w-full bg-cover bg-center bg-no-repeat"
    style="background-image: url('URL-DE-TA-PHOTO.jpg');"
  >
  </div>
</Fragment>
<Fragment slot="back">
  <div class="h-full w-full flex flex-col items-center justify-start px-6 md:px-12 py-20">

    <!-- Titre premium -->
    <h1 class="font-serif text-[28px] md:text-[32px] text-dark tracking-wide text-center mb-2">
      L'orée
    </h1>

    <!-- Ligne fine -->
    <div class="w-20 h-[1px] bg-dark/40 mb-10"></div>

    <!-- Image centrée -->
    <img 
      src="URL-DE-TON-IMAGE"
      alt="Projet Web"
      class="w-full max-w-3xl rounded-2xl shadow-md object-cover"
    />

  </div>
</Fragment>

</Page>
