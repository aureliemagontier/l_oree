---
import '../index.css';
import Hero from '../components/Hero.astro';
import Presentation from '../components/Presentation.astro';
import Services from '../components/Services.astro';
import WebsiteOffer from '../components/WebsiteOffer.astro';
import Pricing from '../components/Pricing.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';
---

<html lang="fr">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>L'orée | Édition 2026</title>
	</head>
	<body class="bg-zinc-100 text-dark min-h-screen flex items-center justify-center p-4 md:p-8 overflow-hidden">
		<div id="magazine-container" class="relative w-full max-w-5xl aspect-[1.5/1] mx-auto">
			<div id="magazine" class="st-page-flip">
				<Hero />
				<Presentation part={1} pageNumber={1} />
				<Presentation part={2} pageNumber={2} />
				<Services part={1} pageNumber={3} />
				<Services part={2} pageNumber={4} />
				<WebsiteOffer part={1} side="left" pageNumber={5} />
				<WebsiteOffer part={2} side="right" pageNumber={6} />
				<Pricing packIndex={0} side="left" pageNumber={7} />
				<Pricing packIndex={1} side="right" pageNumber={8} />
				<Pricing packIndex={2} side="left" pageNumber={9} />
				<Pricing packIndex={3} side="right" pageNumber={10} />
				<Contact part="form" side="left" pageNumber={11} />
				<Contact part="info" side="right" pageNumber={12} />
				<Footer pageNumber={13} />
			</div>

			<!-- Navigation Controls -->
			<div class="absolute -bottom-16 left-0 right-0 flex justify-center gap-8 items-center pt-4">
				<button id="prev-page" class="p-3 rounded-full bg-white shadow-lg border border-zinc-200 text-primary hover:bg-primary hover:text-white transition-all">
					<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-chevron-left"><path d="m15 18-6-6 6-6"/></svg>
				</button>
				<div class="text-xs font-black uppercase tracking-[0.2em] text-dark/40">
					Page <span id="page-number">1</span> / 14
				</div>
				<button id="next-page" class="p-3 rounded-full bg-white shadow-lg border border-zinc-200 text-primary hover:bg-primary hover:text-white transition-all">
					<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-chevron-right"><path d="m9 18 6-6-6-6"/></svg>
				</button>
			</div>
		</div>

		<script>
			import { PageFlip } from 'page-flip';

			document.addEventListener('DOMContentLoaded', () => {
				const magazineElement = document.getElementById('magazine');
				const pageNumberElement = document.getElementById('page-number');
				const prevBtn = document.getElementById('prev-page');
				const nextBtn = document.getElementById('next-page');

				if (!magazineElement) return;

				const pageFlip = new PageFlip(magazineElement, {
					width: 550, // base page width
					height: 733, // base page height
					size: "stretch",
					minWidth: 315,
					maxWidth: 1000,
					minHeight: 420,
					maxHeight: 1350,
					maxShadowOpacity: 0.5,
					showCover: true,
					mobileScrollSupport: false,
					usePortrait: false,
					startPage: 0,
					drawShadow: true,
					flippingTime: 800,
					swipeDistance: 30,
					clickEventForward: true,
					useMouseEvents: true,
				});

				pageFlip.loadFromHTML(document.querySelectorAll('.magazine-page'));

				function updateVisibility() {
					const page = parseInt(pageNumberElement.textContent || '1');
					const hide = page >= 2;
					const verticalUrl = document.getElementById('vertical-url');
					const fakeBarcode = document.getElementById('fake-barcode');
					if (verticalUrl) verticalUrl.style.display = hide ? 'none' : '';
					if (fakeBarcode) fakeBarcode.style.display = hide ? 'none' : '';
				}

				pageFlip.on('flip', (e) => {
					if (pageNumberElement) {
						pageNumberElement.innerText = (e.data + 1).toString();
					}
					updateVisibility();
				});

				updateVisibility(); // initial

				prevBtn?.addEventListener('click', () => {
					pageFlip.flipPrev();
				});

				nextBtn?.addEventListener('click', () => {
					pageFlip.flipNext();
				});

				// Handle navigation buttons inside pages
				magazineElement.addEventListener('click', (e) => {
					const target = e.target as HTMLElement;
					const btnPrev = target.closest('.btn-prev-page');
					const btnNext = target.closest('.btn-next-page');
					const btnEnter = target.closest('#enter-magazine');

					if (btnPrev) {
						e.stopPropagation();
						pageFlip.flipPrev();
					} else if (btnNext || btnEnter) {
						e.stopPropagation();
						pageFlip.flipNext();
					}
				});

				// Handle window resize
				window.addEventListener('resize', () => {
					// pageFlip.update(); // The library handles stretch automatically
				});
			});
		</script>
	</body>
</html>
